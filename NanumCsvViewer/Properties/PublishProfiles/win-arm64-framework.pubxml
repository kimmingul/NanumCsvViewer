<?xml version="1.0" encoding="utf-8"?>
<!--
  단일 파일(프레임워크 의존) ARM64 배포 프로필 — .NET 10 Desktop Runtime(arm64)이 설치된 PC에서 실행.
  CLI: dotnet publish NanumCsvViewer\NanumCsvViewer.csproj -p:PublishProfile=win-arm64-framework
  (x64 호스트에서 교차 게시 가능. 실행/설치 검증은 arm64 기기에서만 가능.)
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-arm64</RuntimeIdentifier>
    <PlatformTarget>ARM64</PlatformTarget>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- 한국어 위성 어셈블리(ko)까지 단일 exe에 포함 -->
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Release\publish-fd-arm64\</PublishDir>
  </PropertyGroup>
</Project>
